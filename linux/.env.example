# SimpleOS Linux Services Configuration

# Kernel Server Configuration
KERNEL_HOST=localhost
KERNEL_PORT=9999
KERNEL_LOG_LEVEL=INFO

# PHP Backend Configuration
PHP_PORT=8080
PHP_HOST=0.0.0.0

# C# ASP.NET Configuration
ASPNET_PORT=5000
ASPNET_HOST=0.0.0.0
ASPNET_ENVIRONMENT=Production

# Python Manager Configuration
PYTHON_PORT=5001
PYTHON_HOST=0.0.0.0
PYTHON_LOG_LEVEL=INFO

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=simpleos
DB_USER=simpleos
DB_PASSWORD=simpleos_secure_password

# Service Configuration
SERVICE_TIMEOUT=30
SERVICE_RETRY_COUNT=3
SERVICE_RETRY_DELAY=5

# Logging Configuration
LOG_DIR=./logs
LOG_MAX_SIZE=10485760
LOG_BACKUP_COUNT=5

# Security Configuration
ENABLE_SSL=false
SSL_CERT_PATH=/etc/simpleos/certs/server.crt
SSL_KEY_PATH=/etc/simpleos/certs/server.key

# Feature Flags
ENABLE_METRICS=true
ENABLE_PROFILING=false
ENABLE_DEBUG_MODE=false

