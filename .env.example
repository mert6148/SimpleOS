# SimpleOS - Örnek ortam değişkenleri
#
# Kopyalayıp `.env` olarak kaydedin ve değerleri doldurun.
# Bu dosya sır içermez; `.env` dosyanızı genelde git'e eklemeyin.

# Electron docs viewer: PHP çalıştırılabilir dosyası (Windows için örnek: C:\php\php.exe)
PHP_PATH=php

# Google OAuth (Google Docs/Drive entegrasyonu kullanıyorsanız)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Google Cloud opsiyonel ayarlar (Cloud Run / Storage / servis hesapları)
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_BUCKET=
GOOGLE_APPLICATION_CREDENTIALS=

