# SimpleOS Project Configuration - Example Template
# USAGE: Copy this file to .env and modify values for your environment
# DO NOT commit .env file to version control - use this template for reference

# ============================================================================
# KERNEL CONFIGURATION
# ============================================================================
KERNEL_DEBUG=1
KERNEL_VERBOSE=0
KERNEL_LOG_LEVEL=2
KERNEL_MAX_TASKS=32
KERNEL_STACK_SIZE=4096
KERNEL_MEMORY_SIZE=268435456

# ============================================================================
# WebSocket BACKEND SERVICE
# ============================================================================
WEBSOCKET_HOST=localhost
WEBSOCKET_PORT=8888
WEBSOCKET_MAX_CONNECTIONS=10
WEBSOCKET_POLLING_INTERVAL_MS=100
WEBSOCKET_TIMEOUT_MS=5000
WEBSOCKET_AUTO_RECONNECT=1

# ============================================================================
# KERNEL SERIAL COMMUNICATION
# ============================================================================
# Linux/macOS: /dev/ttyS0, /dev/ttyUSB0, /dev/cu.usbserial-*
# Windows: COM1, COM2, COM3, etc.
KERNEL_SERIAL_PORT=/dev/ttyS0
KERNEL_BAUD_RATE=9600
KERNEL_TIMEOUT_MS=1000
KERNEL_SERIAL_DEBUG=0

# ============================================================================
# FRONTEND CONFIGURATION (React)
# ============================================================================
REACT_APP_API_URL=http://localhost:8888
REACT_APP_WS_URL=ws://localhost:8888/kernel
REACT_APP_DEBUG=1
REACT_APP_DEMO_MODE=0
REACT_APP_AUTO_REFRESH_MS=100
PORT=3000
HOST=localhost

# ============================================================================
# DEVELOPMENT SETTINGS
# ============================================================================
NODE_ENV=development
DEBUG=simpleos:*

# ============================================================================
# QEMU EMULATION
# ============================================================================
QEMU_MEMORY=256M
QEMU_CPU_CORES=2
QEMU_CPU_TYPE=qemu64
QEMU_DISPLAY=gtk
QEMU_SERIAL_PORT=stdio
QEMU_ENABLE_KVM=0

# ============================================================================
# BUILD CONFIGURATION
# ============================================================================
BUILD_DIR=./build
TARGET_ARCH=x86
TARGET_BITS=32
OPTIMIZE_LEVEL=2
ENABLE_WARNINGS=1
ENABLE_STRICT=0

# ============================================================================
# COMPILER & TOOLCHAIN
# ============================================================================
CC=gcc
CXX=g++
CFLAGS=-Wall -Wextra -O2 -std=c99
CXXFLAGS=-Wall -Wextra -O2 -std=c++17
LD=ld
AR=ar

# ============================================================================
# LOGGING & DIAGNOSTICS
# ============================================================================
LOG_FILE=./logs/simpleos.log
LOG_LEVEL=DEBUG
ENABLE_FILE_LOGGING=1
ENABLE_CONSOLE_LOGGING=1
LOG_TIMESTAMP=1
LOG_TO_SYSLOG=0

# ============================================================================
# DATABASE (Optional - for future extensions)
# ============================================================================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=simpleos_dev
DB_USER=simpleos
DB_PASSWORD=
DB_POOL_SIZE=5

# ============================================================================
# SECURITY
# ============================================================================
ENABLE_AUTH=0
ENABLE_HTTPS=0
JWT_SECRET=change_this_in_production
SESSION_TIMEOUT=3600
CORS_ENABLED=1
CORS_ORIGIN=http://localhost:3000

# ============================================================================
# FEATURE FLAGS
# ============================================================================
ENABLE_REAL_KERNEL=1
ENABLE_DEMO_MODE=0
ENABLE_PROFILING=0
ENABLE_TRACING=0
ENABLE_SANITIZERS=0

# ============================================================================
# THIRD-PARTY INTEGRATIONS (Optional)
# ============================================================================
# Google Integration
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_BUCKET=
GOOGLE_APPLICATION_CREDENTIALS=

# ============================================================================
# DOCUMENTATION
# ============================================================================
DOCS_PORT=8080
DOCS_ENABLE_LIVE_RELOAD=1
DOCS_BUILD_EXAMPLES=1

