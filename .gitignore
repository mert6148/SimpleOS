## SimpleOS - Comprehensive .gitignore

# ============================================================================
# ENVIRONMENT & CONFIGURATION
# ============================================================================
.env
.env.local
.env.*.local
!.env.example
.env.production.local

# ============================================================================
# BUILD & COMPILATION OUTPUT
# ============================================================================
# Object files
*.o
*.obj
*.gch
*.pch

# Executable files
*.exe
*.out
*.app
*.elf
*.bin
*.hex

# Libraries
*.a
*.lib
*.la
*.so
*.so.*
*.dll
*.dylib

# ISO images
*.iso
*.img

# Map files & debug symbols
*.map
*.sym
*.dSYM/

# Compiled binaries
/build/
/dist/
*.bin
kernel/simpleos.elf

# ============================================================================
# BUILD DIRECTORIES & CMake
