{
  "simpleos_docs_service": {
    "version": "1.0.0",
    "api": {
      "base_url": "http://localhost:8000/docs/docsservices.php",
      "timeout": 10,
      "retry_attempts": 3
    },
    "database": {
      "file": "./docs.json",
      "auto_backup": true,
      "backup_dir": "./backups"
    },
    "cache": {
      "enabled": true,
      "directory": "./cache",
      "ttl": 3600
    },
    "search": {
      "min_query_length": 2,
      "max_results": 20,
      "index_content": true
    },
    "google_integration": {
      "enabled": false,
      "client_id": "${GOOGLE_CLIENT_ID}",
      "client_secret": "${GOOGLE_CLIENT_SECRET}",
      "redirect_uri": "http://localhost:8000/docs/google_callback.php",
      "scopes": [
        "https://www.googleapis.com/auth/drive.file",
        "https://www.googleapis.com/auth/drive"
      ]
    },
    "google_search": {
      "enabled": false,
      "api_key": "${GOOGLE_SEARCH_API_KEY}",
      "site_url": "https://simpleos.example.com"
    },
    "export": {
      "formats": ["json", "html", "markdown"],
      "include_metadata": true
    },
    "logging": {
      "enabled": true,
      "level": "info",
      "file": "./logs/docs.log",
      "max_size": "10MB"
    },
    "security": {
      "require_auth": false,
      "api_key": "",
      "cors_enabled": true,
      "allowed_origins": ["*"]
    },
    "sections": {
      "overview": {
        "title": "Overview",
        "description": "SimpleOS project overview and features"
      },
      "architecture": {
        "title": "Architecture",
        "description": "System architecture and components"
      },
      "api": {
        "title": "API Reference",
        "description": "Complete API documentation"
      },
      "examples": {
        "title": "Code Examples",
        "description": "Real-world code examples"
      },
      "guides": {
        "title": "Developer Guides",
        "description": "Step-by-step development guides"
      }
    },
    "windows_app": {
      "app_name": "SimpleOS Documentation Viewer",
      "version": "1.0.0",
      "executable": "simpleos_docs_viewer.exe",
      "icon": "icon.ico",
      "theme": "light",
      "font_size": 11,
      "offline_sync": true
    }
  }
}
